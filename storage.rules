rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // "allowed" is set as a custom claim when the backend mints the Firebase
    // custom token (see functions/index.js: mintFirebaseToken), based on the
    // Supabase editor_whitelist table. There is no Firebase Auth sign-in
    // outside that flow, so this is the single source of truth for who can
    // write here — it does not depend on Firestore at all anymore.
    function isAllowed() {
      return request.auth != null && request.auth.token.allowed == true;
    }

    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if isAllowed(); // covers create/update/delete
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
